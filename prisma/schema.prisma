// WillBee server-side storage (PRD §12 — store completed Wills for re-download)
// and passwordless magic-link auth (PRD §3.5).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled connection used at runtime (serverless). On Vercel + Neon/Supabase
  // this is the pooler URL; DIRECT_URL is the non-pooled URL used for migrations.
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Will {
  id        String    @id @default(cuid())
  email     String    @unique
  fullName  String
  /// JSON-serialised WillData
  data      String
  paid      Boolean   @default(false)
  paymentId String?
  /// Set once the delivery email has been sent — the idempotency lock that
  /// stops the client fast-path and the Stripe webhook from double-sending.
  emailedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([paymentId])
}

model MagicToken {
  token     String   @id
  email     String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([email])
}

// Marketing leads captured from Meta (Facebook/Instagram) Lead Ads, driven
// through a 3-stage nurture email sequence.
model Lead {
  id          String    @id @default(cuid())
  email       String    @unique
  name        String?
  source      String    @default("meta")
  /// Meta leadgen_id, kept for idempotency / debugging.
  leadgenId   String?
  formId      String?
  /// Number of sequence emails sent so far (0..3).
  stage       Int       @default(0)
  /// When the next sequence email is due (null once finished).
  nextEmailAt DateTime?
  /// active | completed | unsubscribed | converted | bounced
  status      String    @default("active")
  /// Opaque token used for one-click unsubscribe links.
  unsubToken  String    @unique
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, nextEmailAt])
  @@index([leadgenId])
}
