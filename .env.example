# ── WillBee environment ──────────────────────────────────────────────────────
# Copy to .env and fill in. NEVER commit real secret values. With Stripe/Resend
# keys blank the app runs in DEMO mode (payment simulated, no real email sent).

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
# DATABASE_URL is the POOLED connection used at runtime (serverless). DIRECT_URL
# is the non-pooled connection used for migrations (`prisma migrate deploy`).
# On Neon: DATABASE_URL = the "-pooler" host; DIRECT_URL = the direct host.
# On Supabase: DATABASE_URL = port 6543 (pgBouncer, add ?pgbouncer=true);
#              DIRECT_URL   = port 5432.
# For local dev, run Postgres (e.g. `docker run -e POSTGRES_PASSWORD=postgres \
#   -p 5432:5432 postgres`) and point both URLs at it.
DATABASE_URL="postgresql://user:password@host:5432/willbee?sslmode=require"
DIRECT_URL="postgresql://user:password@host:5432/willbee?sslmode=require"

# Base URL used in magic-link emails. In production set to your live origin,
# e.g. https://will.willbee.site
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ── Stripe ───────────────────────────────────────────────────────────────────
# Use test keys (sk_test_…/pk_test_…) until you're ready for live (sk_live_…).
# Leave blank to enable demo checkout.
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
# Signing secret for the /api/stripe-webhook endpoint (whsec_…). From the Stripe
# dashboard webhook, or `stripe listen` when testing locally.
STRIPE_WEBHOOK_SECRET=""

# ── Resend (email) ───────────────────────────────────────────────────────────
# Leave RESEND_API_KEY blank to skip real email sends.
RESEND_API_KEY=""
# Must be an address on a domain you've verified in Resend.
RESEND_FROM="WillBee <noreply@will.willbee.site>"

# ── Auth ─────────────────────────────────────────────────────────────────────
# Secret that signs the passwordless session cookie. Generate a strong value:
#   openssl rand -base64 32
AUTH_SECRET="dev-only-change-me"
